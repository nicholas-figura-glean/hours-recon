# Application: demo, mcp, or live (direct APIs)
HOURS_RECON_MODE=mcp
HOURS_RECON_MCP_SNAPSHOT_PATH=var/mcp_snapshot.json
HOURS_RECON_HOST=127.0.0.1
HOURS_RECON_PORT=8765
HOURS_RECON_REQUESTER_EMAIL=your.name@example.com
HOURS_RECON_TIMEZONE=America/Denver
HOURS_RECON_CACHE_MAX_AGE_DAYS=30

# Governance and local remediation workflow. Observe-only preserves reported totals
# while separating governed/provisional exposure and opening Tier 3/4 cases.
HOURS_RECON_GOVERNANCE_MODE=observe_only
HOURS_RECON_REMEDIATION_MODE=observe_only
HOURS_RECON_REMEDIATION_DB_PATH=var/remediation.sqlite3
# Required for remediation validation transitions. Must exactly match the MCP
# snapshot's connector-verified meta.scope_id.
HOURS_RECON_REMEDIATION_SCOPE_ID=

# The values below are only needed for HOURS_RECON_MODE=live.
# Salesforce: either provide a current access token + instance URL,
# or use an OAuth connected app refresh token.
SF_API_VERSION=62.0
SF_INSTANCE_URL=https://your-domain.my.salesforce.com
SF_ACCESS_TOKEN=
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REFRESH_TOKEN=

# Optional override if automatic Account field discovery is ambiguous.
SF_AIOM_FIELD=
SF_AIOM_MATCH_VALUE=

# Rocketlane
ROCKETLANE_BASE_URL=https://api.rocketlane.com/api/1.0
ROCKETLANE_API_KEY=
